#!/usr/bin/env sh

# 프론트엔드 실행 코드(ts/tsx/js/jsx) 변경 감지
FRONTEND_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR -- 'packages/frontend/src/**/*.ts' 'packages/frontend/src/**/*.tsx' 'packages/frontend/src/**/*.js' 'packages/frontend/src/**/*.jsx')

if [ -n "$FRONTEND_CHANGED" ]; then
  echo "🔍 프론트엔드 실행 코드 변경 감지 — lint fix, build, test 실행"

  # 1. lint-staged (staged 파일에 대해 eslint --fix)
  npx lint-staged || exit 1

  # 2. build
  echo "📦 프론트엔드 빌드..."
  npm run build -w @todo-app/frontend || exit 1

  # 3. test
  echo "🧪 프론트엔드 테스트..."
  npm test -w @todo-app/frontend || exit 1

  echo "✅ 프론트엔드 검증 완료"
fi
